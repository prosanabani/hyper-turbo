{

  "extends": "@repo/tsconfig/base.json",

  "compilerOptions": {

    "lib": ["ES2022", "dom", "dom.iterable"],

    "jsx": "preserve",

    "rootDir": ".",

    "baseUrl": ".",

    "paths": {

      "@repo/ui": ["./src/index.ts"],

      "@repo/ui/src": ["./src"],

      "@repo/ui/src/*": ["./src/*"],

      "@repo/ui/components": ["./src/components"],

      "@repo/ui/components/*": ["./src/components/*"],

      "@repo/ui/hooks": ["./src/hooks"],

      "@repo/ui/hooks/*": ["./src/hooks/*"],

      "@repo/ui/lib": ["./src/lib"],

      "@repo/ui/lib/*": ["./src/lib/*"]

    }

  },

  "include": ["src"],

  "exclude": ["node_modules"]

}

